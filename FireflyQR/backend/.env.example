# Copy to .env and fill in your values. Do not commit .env.

# Chain
RPC_URL=https://your-rpc-endpoint
CHAIN_ID=0

# Redis
REDIS_ADDR=127.0.0.1:6379

# BookFactory
FACTORY_ADDR=0xYourFactoryAddress
TREASURY_ADDRESS=0xYourTreasuryEOA
SECONDARY_ACTIVATE_RECEIVER=0xYourEOAForSecondaryActivate

# Relayer (gasless mint) — use a dedicated EOA, no 0x prefix
RELAYER_COUNT=1
PRIVATE_KEY_0=your64charhex
RELAYER_PRIVATE_KEY=your64charhex
BACKEND_PRIVATE_KEY=your64charhex

# Optional: GeoIP, USDT, etc.
# GEOLITE2_CITY_MMDB=/path/to/GeoLite2-City.mmdb
