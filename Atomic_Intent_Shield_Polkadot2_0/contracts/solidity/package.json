{
  "name": "polkashield-solidity",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node ./scripts/hardhat-run.cjs compile",
    "test": "node ./scripts/hardhat-run.cjs test",
    "deploy:revive": "node ./scripts/hardhat-run.cjs run scripts/deploy.ts --network revive",
    "deploy:mocks": "node ./scripts/hardhat-run.cjs run scripts/deploy-mocks.ts --network revive",
