  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "abort-controller": "^3.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.17.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
