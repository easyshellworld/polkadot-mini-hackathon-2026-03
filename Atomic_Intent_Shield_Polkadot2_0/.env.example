# ============================================================
# Atomic Intent for Polkadot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ----- Substrate Node -----
SUBSTRATE_RPC_URL=ws://127.0.0.1:9944

# ----- Solver -----
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
SOLVER_MNEMONIC=//Alice
MATCHING_INTERVAL_MS=5000
MAX_BATCH_SIZE=50

# ----- Redis -----
REDIS_URL=redis://127.0.0.1:6379

# ----- Auth -----
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY_HOURS=24

# ----- Protocol -----
PROTOCOL_FEE_BPS=30
FEE_RECIPIENT=5GrwvaEF5zXb26Fz9rcQpDWS57CtERHpNehXCPcNoHGKutQY

# ----- Contract Addresses (filled after deployment) -----
DARK_POOL_CONTRACT=
INTENT_VERIFIER_CONTRACT=
GROTH16_VERIFIER_CONTRACT=

# ----- Frontend -----
VITE_SOLVER_API_URL=http://localhost:3001
VITE_SUBSTRATE_RPC_URL=ws://localhost:9944
VITE_DARK_POOL_CONTRACT=
VITE_WETH_PASEO_CONTRACT=
# Optional (ETH -> PAS flow): EVM-side ERC20 approve target setup
VITE_EVM_WETH_TOKEN_ADDRESS=
VITE_EVM_BRIDGE_SPENDER_ADDRESS=
VITE_APP_NAME=Atomic Intent for Polkadot

# ----- Logging -----
RUST_LOG=info,solver=debug

# ----- Snowbridge (Cross-chain EVM Settlement) -----
# Set SNOWBRIDGE_ENABLED=true to submit real Sepolia transactions
SNOWBRIDGE_ENABLED=false
SNOWBRIDGE_EVM_RPC=https://ethereum-sepolia-rpc.publicnode.com
# Private key of a funded Sepolia wallet (hex, no 0x prefix)
SNOWBRIDGE_EVM_PRIVATE_KEY=
# Target address for bridge settlement txs on Sepolia
SNOWBRIDGE_SETTLEMENT_ADDRESS=0x000000000000000000000000000000000000dEaD
